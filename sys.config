%% ErlBASIC System Configuration
%% This file configures runtime parameters for the application.
%%
%% Place this file in one of these locations:
%%   - Current directory: ./sys.config
%%   - Config directory: ./config/sys.config
%%   - Release directory: _build/default/rel/erlbasic/releases/0.1.0/sys.config
%%
%% Start with: erl -config sys.config -s erlbasic_app

[
  {erlbasic, [
    %% HTTP Configuration
    {http_port, 8081},
    
    %% HTTPS Configuration
    %% Set enable_https to true to start HTTPS listener
    {enable_https, true},
    {https_port, 8443},
    {certfile, "priv/ssl/cert.pem"},
    {keyfile, "priv/ssl/key.pem"}
    %% Optional: uncomment if using CA certificate
    %% {cacertfile, "priv/ssl/cacert.pem"}
  ]},
  
  {kernel, [
    %% Logging configuration
    {logger_level, info},
    {logger, [
      {handler, default, logger_std_h,
        #{level => info,
          formatter => {logger_formatter, #{
            single_line => false,
            time_designator => $ 
          }}
        }
      }
    ]}
  ]}
].

%% CONFIGURATION EXAMPLES:
%%
%% === Development Mode (HTTP only) ===
%% {erlbasic, [
%%   {http_port, 8081},
%%   {enable_https, false}
%% ]}
%%
%% === Development Mode (HTTPS with self-signed certs) ===
%% Generate certificates first: pwsh generate_certs.ps1
%% {erlbasic, [
%%   {http_port, 8081},
%%   {enable_https, true},
%%   {https_port, 8443},
%%   {certfile, "priv/ssl/cert.pem"},
%%   {keyfile, "priv/ssl/key.pem"}
%% ]}
%%
%% === Production Mode (HTTPS with Let's Encrypt) ===
%% {erlbasic, [
%%   {http_port, 80},
%%   {enable_https, true},
%%   {https_port, 443},
%%   {certfile, "/opt/erlbasic/priv/ssl/cert.pem"},
%%   {keyfile, "/opt/erlbasic/priv/ssl/key.pem"}
%% ]}
%%
%% === Behind Reverse Proxy (nginx/Apache) ===
%% Run on high ports, let proxy handle SSL
%% {erlbasic, [
%%   {http_port, 8081},
%%   {enable_https, false}
%% ]}
