10 REM STARS AND STRIPES FOREVER + ASCII FIREWORKS SHOW
20 REM REQUIRES WEBSOCKET WEB CLIENT (SOUND + LOCATE)
30 CLS
40 COLOR 14
50 LOCATE 1,1: PRINT "STARS AND STRIPES FOREVER"
60 COLOR 11
70 LOCATE 2,1: PRINT "FIREWORKS INTRO -> FULL TUNE -> FIREWORKS OUTRO"
80 COLOR 10
90 LOCATE 3,1: PRINT "PRESS CTRL-C TO STOP"
100 LET CH = 0
110 LET DIST = 10
120 LET VOL = 12
130 LET TEMPO = 0.062
135 LET SOUNDK = 36000
140 DIM P(900), D(900)
150 LET NOTECOUNT = 0
160 GOSUB 9000
170 REM SHOW LOOP
180 GOSUB 5000
190 GOSUB 6000
200 GOSUB 7000
210 GOTO 180
220 END

3000 REM PLAY CURRENT NOTE (N IS MIDI-LIKE NOTE NUMBER)
3010 IF N = 0 THEN SOUND CH, 0, 0, 0: SLEEP TEMPO * L: RETURN
3020 LET FREQ = 440 * POW(2, (N - 69) / 12)
3030 LET TMP = SOUNDK / FREQ
3040 LET PITCH = INT(TMP)
3050 LET PITCH = PITCH - 2
3060 IF PITCH < 0 THEN PITCH = 0
3070 IF PITCH > 255 THEN PITCH = 255
3080 SOUND CH, PITCH, DIST, VOL
3090 SLEEP TEMPO * L
3100 SOUND CH, 0, 0, 0
3110 RETURN

4000 REM ONE FIREWORK BURST
4010 LET X = INT(RND(1) * 66) + 6
4020 LET Y = INT(RND(1) * 14) + 6
4030 LET C = INT(RND(1) * 15) + 1
4040 COLOR C
4050 LET R = INT(RND(1) * 5)
4060 IF R = 0 THEN S$ = "*"
4070 IF R = 1 THEN S$ = "+"
4080 IF R = 2 THEN S$ = "o"
4090 IF R = 3 THEN S$ = "x"
4100 IF R = 4 THEN S$ = "@"
4110 LOCATE Y, X: PRINT S$;
4120 LOCATE Y-1, X: PRINT S$;
4130 LOCATE Y+1, X: PRINT S$;
4140 LOCATE Y, X-2: PRINT S$;
4150 LOCATE Y, X+2: PRINT S$;
4160 LOCATE Y-1, X-1: PRINT S$;
4170 LOCATE Y-1, X+1: PRINT S$;
4180 LOCATE Y+1, X-1: PRINT S$;
4190 LOCATE Y+1, X+1: PRINT S$;
4200 SLEEP 0.02
4210 COLOR 8
4220 LOCATE Y-2, X: PRINT ".";
4230 LOCATE Y+2, X: PRINT ".";
4240 LOCATE Y, X-3: PRINT ".";
4250 LOCATE Y, X+3: PRINT ".";
4260 SLEEP 0.02
4270 LOCATE Y, X: PRINT " ";
4280 LOCATE Y-1, X: PRINT " ";
4290 LOCATE Y+1, X: PRINT " ";
4300 LOCATE Y, X-2: PRINT " ";
4310 LOCATE Y, X+2: PRINT " ";
4320 LOCATE Y-1, X-1: PRINT " ";
4330 LOCATE Y-1, X+1: PRINT " ";
4340 LOCATE Y+1, X-1: PRINT " ";
4350 LOCATE Y+1, X+1: PRINT " ";
4360 LOCATE Y-2, X: PRINT " ";
4370 LOCATE Y+2, X: PRINT " ";
4380 LOCATE Y, X-3: PRINT " ";
4390 LOCATE Y, X+3: PRINT " ";
4400 RETURN

5000 REM INTRO FIREWORKS (A FEW SECONDS)
5010 FOR T = 1 TO 22
5020   GOSUB 4000
5030 NEXT T
5040 RETURN

6000 REM PLAY FULL TUNE (SINGLE-VOICE ARRANGEMENT)
6010 FOR I = 1 TO NOTECOUNT
6020   LET N = P(I)
6030   LET L = D(I)
6040   GOSUB 3000
6050 NEXT I
6060 SOUND CH, 0, 0, 0
6070 RETURN

7000 REM OUTRO FIREWORKS
7010 FOR T = 1 TO 16
7020   GOSUB 4000
7030 NEXT T
7040 RETURN

9000 REM READ DATA ONCE INTO ARRAYS (NO RESTORE STATEMENT NEEDED)
9010 LET J = 1
9020 READ N, L
9030 IF N = -1 THEN NOTECOUNT = J - 1: RETURN
9040 P(J) = N
9050 D(J) = L
9060 LET J = J + 1
9070 GOTO 9020

