10 REM AMERICAN FLAG - 13 STRIPES, STAGGERED 6/5 STAR CANTON
20 CLS
30 PRINT "  AMERICAN FLAG"
40 PRINT
50 FOR R = 1 TO 13
60 IF R MOD 2 = 1 THEN SC = 4
70 IF R MOD 2 = 0 THEN SC = 7
80 IF R MOD 2 = 1 THEN FC = 15
90 IF R MOD 2 = 0 THEN FC = 1
100 IF R > 7 THEN GOTO 300
110 REM CANTON (BLUE BG, 24 CHARS) FOLLOWED BY PARTIAL STRIPE (36 CHARS)
120 COLOR 15, 1
130 IF R MOD 2 = 1 THEN GOSUB 500
140 IF R MOD 2 = 0 THEN GOSUB 600
150 COLOR FC, SC
160 PRINT STRING$(36, 61);
170 PRINT
180 GOTO 400
300 REM FULL-WIDTH STRIPE (60 CHARS)
310 COLOR FC, SC
320 PRINT STRING$(60, 61);
330 PRINT
400 NEXT R
410 COLOR 7
420 PRINT
430 PRINT "  LONG LIVE THE REPUBLIC!"
440 END
500 REM ODD CANTON ROW: 6 STARS, EACH FOLLOWED BY 3 SPACES (6*4=24 CHARS)
510 FOR I = 1 TO 6
520 PRINT "*"; STRING$(3, 32);
530 NEXT I
540 RETURN
600 REM EVEN CANTON ROW: 2 LEADING + 5 STARS + 2 TRAILING (2+5*4+2=24 CHARS)
610 PRINT STRING$(2, 32);
620 FOR I = 1 TO 5
630 PRINT "*"; STRING$(3, 32);
640 NEXT I
650 PRINT STRING$(2, 32);
660 RETURN
