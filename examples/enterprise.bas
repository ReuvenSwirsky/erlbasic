10 REM STARSHIP ENTERPRISE (SIDE VIEW) WITH TWINKLING STARS
20 COLOR 0,0
25 CLS
30 COLOR 7,0
40 PRINT "STARSHIP ENTERPRISE - NCC-1701"
50 PRINT
60 N = 45
70 DIM SX(50), SY(50)
80 FOR I = 1 TO N
90 GOSUB 2000
100 NEXT I
110 GOSUB 1000
120 FOR F = 1 TO 240
130 GOSUB 3000
140 GOSUB 4000
150 SLEEP 0.08
160 NEXT F
170 COLOR 7,0
180 LOCATE 24, 1
190 PRINT "END OF TRANSMISSION"
200 END
1000 REM DRAW ENTERPRISE (SIDE PROFILE)
1010 COLOR 10,0
1020 LOCATE 6,2: PRINT "  ______________________________________________"
1030 LOCATE 7,2: PRINT " /      (==============)      /   /"
1040 LOCATE 8,2: PRINT "/______                _______/   /________    ________"
1050 LOCATE 9,2: PRINT "       \______________/      \___/        \____/       \___"
1060 LOCATE 10,2: PRINT "             \    \                    _/    _"
1070 LOCATE 11,2: PRINT "              \    \__________________/    _/  \_____"
1080 LOCATE 12,2: PRINT "         ______\                    ____ _/          \_____"
1090 LOCATE 13,2: PRINT "        /_______\__________________/                 ______/"
1100 LOCATE 14,2: PRINT "                    \______________/"
1110 COLOR 2,0
1120 LOCATE 8,68: PRINT "<=>"
1130 LOCATE 12,74: PRINT "==>"
1140 COLOR 10,0
1150 RETURN
2000 REM PLACE STAR I OUTSIDE SHIP BOUNDING BOX
2010 X = INT(RND(1) * 78) + 1
2020 Y = INT(RND(1) * 19) + 4
2030 IF Y < 5 THEN GOTO 2080
2040 IF Y > 15 THEN GOTO 2080
2050 IF X < 2 THEN GOTO 2080
2060 IF X > 78 THEN GOTO 2080
2070 GOTO 2010
2080 SX(I) = X
2090 SY(I) = Y
2100 RETURN
3000 REM TWINKLE STARS
3010 FOR I = 1 TO N
3020 COLOR 0,0
3030 LOCATE SY(I), SX(I)
3040 PRINT " ";
3050 GOSUB 2000
3060 B = INT(RND(1) * 4)
3070 IF B = 0 THEN CH$ = "."
3080 IF B = 1 THEN CH$ = "+"
3090 IF B = 2 THEN CH$ = "*"
3100 IF B = 3 THEN CH$ = "."
3110 C = 8 + INT(RND(1) * 8)
3120 COLOR C,0
3130 LOCATE SY(I), SX(I)
3140 PRINT CH$;
3150 NEXT I
3160 RETURN
4000 REM SUBTLE ENGINE PULSE
4010 P = F MOD 6
4020 IF P < 3 THEN GOTO 4060
4030 COLOR 2,0
4040 LOCATE 8,68: PRINT "<=>"
4050 LOCATE 12,74: PRINT "==>"
4055 RETURN
4060 COLOR 15,0
4070 LOCATE 8,68: PRINT "<=>"
4080 LOCATE 12,74: PRINT "==>"
4090 COLOR 10,0
4100 RETURN
