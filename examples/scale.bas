10 REM C MAJOR SCALE - 2 OCTAVES UP AND DOWN
20 REM REQUIRES WEBSOCKET CLIENT FOR SOUND
30 LET SOUNDK = 36000
40 LET TEMPO = 0.22
50 LET CH = 0
60 LET DIST = 10
70 LET VOL = 12
80 READ N
90 IF N = -1 THEN GOTO 300
100 LET FREQ = 440 * POW(2, (N - 69) / 12)
110 LET TMP = SOUNDK / FREQ
120 LET PITCH = INT(TMP)
130 LET PITCH = PITCH - 2
140 IF PITCH < 0 THEN PITCH = 0
150 IF PITCH > 255 THEN PITCH = 255
160 SOUND CH, PITCH, DIST, VOL
170 SLEEP TEMPO
180 SOUND CH, 0, 0, 0
190 SLEEP 0.03
200 GOTO 80
300 END
400 DATA 60,62,64,65,67,69,71,72,74,76,77,79,81,83,84
410 DATA 83,81,79,77,76,74,72,71,69,67,65,64,62,60
420 DATA -1
