10 REM Test bitwise AND, OR, XOR, NOT operators
20 REM Test AND
30 LET A = 12 AND 10
40 PRINT A
50 REM 12 = 1100, 10 = 1010, AND = 1000 = 8
60 REM Test OR
70 LET B = 12 OR 3
80 PRINT B
90 REM 12 = 1100, 3 = 0011, OR = 1111 = 15
100 REM Test XOR
110 LET C = 12 XOR 10
120 PRINT C
130 REM 12 = 1100, 10 = 1010, XOR = 0110 = 6
140 REM Test NOT
150 LET D = NOT 0
160 PRINT D
170 REM NOT 0 = -1
180 LET E = NOT 255
190 PRINT E
200 REM NOT 255 = -256
210 REM Test with byte variables
220 LET F& = 128 OR 64
230 PRINT F&
240 REM 128 OR 64 = 192
250 LET G& = 255 AND 15
260 PRINT G&
270 REM 255 AND 15 = 15
